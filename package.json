{
  "name": "git-agents",
  "version": "0.1.2",
  "description": "TUI CLI to sync your AI agents and skills across machines using git",
  "type": "module",
  "license": "MIT",
  "author": "Florent Klein",
  "keywords": [
    "git",
    "tui",
    "cli",
    "claude",
    "agents",
    "skills",
    "sync",
    "worktree"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floklein/git-agents.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ga": "dist/index.js",
    "git-agents": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opentui/core": "^0.1.95",
    "@opentui/react": "^0.1.95",
    "@types/bun": "latest",
    "react": "^19.2.4",
    "typescript": "^5"
  }
}
